# --- Leonex Discord Bot Configuration ---

# Discord Bot Credentials
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# MongoDB Connection
# Example: mongodb://localhost:27017/leonex or MongoDB Atlas URI
MONGODB_URI=mongodb://localhost:27017/leonex

# AI Integration (Optional - Fallback to rule-based conversational AI if empty)
GEMINI_API_KEY=your_gemini_api_key_here

# Web Dashboard Configuration
DASHBOARD_PORT=3000
DASHBOARD_SECRET=somelongrandomsecretstringhere
DASHBOARD_CLIENT_SECRET=your_discord_client_secret_here
DASHBOARD_CALLBACK_URL=http://localhost:3000/auth/callback
